// ============================================
// Syncthing ignore patterns for HA config sync
// Matches .gitignore — skip HA runtime, secrets, managed dirs
// ============================================

// --- Databases & Logs ---
home-assistant.log*
home-assistant_v2.db
home-assistant_v2.db-shm
home-assistant_v2.db-wal
*.db-journal
*.pid

// --- Sensitive files ---
secrets.yaml
.ssh
ssh_keys

// --- HA runtime / internal ---
.cloud
.storage
.shopping_list.json
.ha_run.lock
.HA_VERSION
.cache

// --- Dependencies & generated ---
deps
tts

// --- HACS / custom components ---
custom_components

// --- Frontend assets ---
www

// --- Blueprints (stock HA) ---
blueprints

// --- Themes (HACS-managed) ---
themes

// --- Backups ---
yaml_backups

// --- ESPHome build artifacts ---
esphome/.esphome

// --- Zigbee2MQTT runtime ---
zigbee2mqtt/database.db
zigbee2mqtt/log
zigbee2mqtt/state.json
zigbee2mqtt/coordinator_backup.json

// --- Git internals ---
.git

// --- OS / Editor junk ---
__pycache__
*.pyc
.DS_Store
Thumbs.db
*.swp
*.swo
*~

// --- Sync tooling ---
.ha-sync

// --- VS Code workspace settings ---
.vscode
