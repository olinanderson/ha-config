# ============================================
# Home Assistant .gitignore
# ============================================

# --- Databases & Logs ---
home-assistant.log*
home-assistant_v2.db
home-assistant_v2.db-shm
home-assistant_v2.db-wal
vanlife_tracker.db
vanlife_tracker.db-shm
vanlife_tracker.db-wal
starlink_gps_backup.db*
db_backups/
*.db
*.db-shm
*.db-wal
*.db-journal
*.pid

# --- Sensitive files (NEVER commit) ---
secrets.yaml
.ssh/
ssh_keys/
.dvr_credentials

# --- HA runtime / internal ---
.cloud/
.storage/
.shopping_list.json
.ha_run.lock
.HA_VERSION
.cache/

# --- Dependencies & generated ---
deps/
tts/

# --- HACS / custom components (managed by HACS, not hand-edited) ---
# Ignore everything inside custom_components except vanlife_tracker
custom_components/*
!custom_components/vanlife_tracker/

# --- Frontend assets (HACS-managed cards) ---
www/community/

# --- Static assets (sounds, images, etc.) ---
www/sounds/
www/images/

# --- Frontend runtime caches ---
www/vanlife-panel/route_cache.db
www/vanlife-panel/osrm_proxy.log
www/vanlife-panel/gps_filter.log
.gps_filter_token

# --- Zigbee2MQTT (managed by Z2M, not hand-edited) ---
zigbee2mqtt/

# --- ESPHome build artifacts ---
esphome/.esphome/
esphome/esphome-components/

# --- Blueprints (stock HA blueprints, auto-managed) ---
blueprints/

# --- OS / Editor junk ---
__pycache__/
*.pyc
.DS_Store
Thumbs.db
nul
*.swp
*.swo
*~
ha_config.code-workspace

# --- Backups (large, keep locally but not in repo) ---
yaml_backups/

# --- Themes (HACS-managed) ---
themes/

# --- Syncthing (bidirectional sync with PC) ---
.stfolder/
.stversions/
.ha-sync/
*.sync-conflict-*
~syncthing~*
