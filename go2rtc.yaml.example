# Example go2rtc.yaml — copy to go2rtc.yaml and fill in real RTSP creds.
# The real file is gitignored; do NOT commit credentials.
#
# Streams are managed by HA's go2rtc integration (via camera entities).
# Do NOT define streams here that duplicate the integration's connections.
streams:
  channel_1:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=1&subtype=0
  channel_2:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=2&subtype=0
  channel_3:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=3&subtype=0
  channel_4:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=4&subtype=0
  channel_1_sub:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=1&subtype=1
  channel_2_sub:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=2&subtype=1
  channel_3_sub:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=3&subtype=1
  channel_4_sub:
    - rtsp://USER:PASS@DVR_HOST:554/cam/realmonitor?channel=4&subtype=1
